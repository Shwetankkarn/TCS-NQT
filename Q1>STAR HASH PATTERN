import java.util.Scanner;


public class Main
{
	public static void main(String[] args) {
	
	Scanner sc= new Scanner(System.in);
	String s= sc.nextLine();
	
	int starCount=0;
	int hashCount=0;
	for(int i=0; i<s.length(); i++){
	    
	    if (s.charAt(i)=='*'){
	        starCount++;
	    }
       else if (s.charAt(i)=='#'){
	        hashCount++;
	    }
	}
	System.out.println(starCount-hashCount);
	
	}
}
